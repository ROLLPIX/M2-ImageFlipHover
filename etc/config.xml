<?xml version="1.0"?>
<!--
/**
 * @author Rollpix
 * @package Rollpix_ImageFlipHover
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <rollpix_imageflip>
            <general>
                <enabled>1</enabled>
                <mode>flip</mode>
            </general>
            <flip>
                <primary_role>second_image</primary_role>
                <fallback_role>second_image</fallback_role>
                <animation_type>fade</animation_type>
                <animation_speed>300</animation_speed>
            </flip>
            <hover_slider>
                <enable_hover_flip>1</enable_hover_flip>
                <transition_type>fade</transition_type>
                <transition_speed>250</transition_speed>
                <max_images>8</max_images>
                <configurable_images_per_child>0</configurable_images_per_child>
                <loop>0</loop>
            </hover_slider>
            <desktop>
                <enabled>1</enabled>
                <navigation>arrows</navigation>
                <indicator>bars</indicator>
                <indicator_position>top</indicator_position>
            </desktop>
            <mobile>
                <enabled>0</enabled>
                <navigation>swipe</navigation>
                <indicator>bars</indicator>
                <indicator_position>top</indicator_position>
            </mobile>
            <locations>
                <category_page>1</category_page>
                <widget_products>1</widget_products>
                <search_results>1</search_results>
                <related_products>1</related_products>
                <cms_blocks>1</cms_blocks>
                <page_builder>1</page_builder>
            </locations>
        </rollpix_imageflip>
    </default>
</config>

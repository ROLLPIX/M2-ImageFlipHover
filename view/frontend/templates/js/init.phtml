<?php
/**
 * @author Rollpix
 * @package Rollpix_ImageFlipHover
 *
 * JavaScript initialization template
 *
 * @var \Magento\Framework\View\Element\Template $block
 * @var \Magento\Framework\Escaper $escaper
 * @var \Rollpix\ImageFlipHover\ViewModel\ImageFlip $viewModel
 */

$viewModel = $block->getData('view_model');

if (!$viewModel->isEnabled()) {
    return;
}

$jsModule = $viewModel->getMode() === 'slider'
    ? 'Rollpix_ImageFlipHover/js/hover-slider'
    : 'Rollpix_ImageFlipHover/js/image-flip';
?>
<script type="text/x-magento-init">
{
    "*": {
        "<?= /* @noEscape */ $jsModule ?>": <?= /* @noEscape */ $viewModel->getConfigJson() ?>
    }
}
</script>

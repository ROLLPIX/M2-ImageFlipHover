<?php
/**
 * @author Rollpix
 * @package Rollpix_ImageFlipHover
 *
 * JavaScript initialization template.
 * Always loads hover-slider.js which handles both flip and slider modes.
 * In flip mode on desktop: hover shows image 2 (no controls for 2-image products).
 * In flip mode on mobile: auto-upgrades to slider with swipe + indicators.
 *
 * @var \Magento\Framework\View\Element\Template $block
 * @var \Magento\Framework\Escaper $escaper
 * @var \Rollpix\ImageFlipHover\ViewModel\ImageFlip $viewModel
 */

$viewModel = $block->getData('view_model');

if (!$viewModel->isEnabled()) {
    return;
}
?>
<script type="text/x-magento-init">
{
    "*": {
        "Rollpix_ImageFlipHover/js/hover-slider": <?= /* @noEscape */ $viewModel->getConfigJson() ?>
    }
}
</script>

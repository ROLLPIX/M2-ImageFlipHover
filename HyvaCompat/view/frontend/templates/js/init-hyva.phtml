<?php
/**
 * @author Rollpix
 * @package Rollpix_ImageFlipHoverHyvaCompat
 *
 * Vanilla JS (no jQuery) — port of hover-slider.js for Hyvä themes.
 * Same logic: track approach for all transitions, overlays removed.
 */
$viewModel = $block->getData('view_model');
if (!$viewModel || !$viewModel->isEnabled()) { return; }
$configJson = $viewModel->getConfigJson();
?>
<script>
(function() {
    'use strict';
    var config = <?= /* @noEscape */ $configJson ?>;
    if (!config.enabled) return;

    var isTouchDevice = ('ontouchstart' in window) || window.matchMedia('(hover: none)').matches;
    var initTimeout = null;

    function shouldEnable() {
        if (!config.desktopOnly) return true;
        return window.innerWidth >= 768;
    }

    function initAll() {
        if (config.mode === 'slider') initSliders();
        else initFlipImages();
    }

    // =============================================
    // FLIP MODE (existing behavior)
    // =============================================
    function initFlipImages() {
        if (!shouldEnable()) return;
        document.querySelectorAll('[data-flip-image="true"]:not(.flip-initialized)').forEach(function(el) {
            el.classList.add('flip-initialized');
            var flipImg = el.querySelector('.flip-image');
            var flipUrl = el.dataset.flipUrl;
            if (flipImg && flipUrl && !flipImg.src) {
                el.addEventListener('mouseenter', function f() { flipImg.src = flipUrl; el.removeEventListener('mouseenter', f); });
            }
            el.addEventListener('mouseenter', function() {
                if (flipImg && flipUrl && !flipImg.src) flipImg.src = flipUrl;
                el.classList.add('is-flipped');
            });
            el.addEventListener('mouseleave', function() { el.classList.remove('is-flipped'); });
        });
    }

    // =============================================
    // SLIDER MODE
    // =============================================
    function initSliders() {
        if (!shouldEnable()) return;
        document.querySelectorAll('[data-hover-slider="true"]:not(.slider-initialized)').forEach(function(el) {
            createSlider(el);
        });
    }

    function createSlider(container) {
        var galleryData = container.dataset.gallery;
        var sliderConfigData = container.dataset.sliderConfig;
        if (!galleryData || !sliderConfigData) return;

        var images = JSON.parse(galleryData);
        var cfg = JSON.parse(sliderConfigData);
        if (images.length < 2) return;

        var deviceCfg = isTouchDevice ? cfg.mobile : cfg.desktop;
        var showControls = isTouchDevice ? true : images.length > 2;

        var state = {
            el: container,
            viewport: container.querySelector('.hover-slider-viewport'),
            images: images,
            currentIndex: 0,
            cfg: cfg,
            deviceCfg: deviceCfg,
            slides: [],
            track: null,
            slidesCreated: false,
            arrows: null,
            indicators: null,
            counter: null
        };

        container.classList.add('slider-initialized');

        // Preload all images
        for (var i = 1; i < images.length; i++) { var img = new Image(); img.src = images[i]; }

        if (showControls) {
            if (deviceCfg.nav && deviceCfg.nav.indexOf('arrows') !== -1) createArrows(state);
            if (deviceCfg.nav && deviceCfg.nav.indexOf('mouse_tracking') !== -1 && !isTouchDevice) {
                container.classList.add('nav-mouse-tracking');
                initMouseTracking(state);
            }
            if (deviceCfg.nav && deviceCfg.nav.indexOf('swipe') !== -1) initSwipe(state);
            createIndicators(state);
        }

        bindHoverEvents(state);
    }

    // =============================================
    // SLIDES (created on first hover)
    // =============================================
    function ensureSlidesCreated(state) {
        if (state.slidesCreated) return;
        state.slidesCreated = true;

        var vp = state.viewport;
        var baseImg = vp.querySelector('img');
        var alt = baseImg ? baseImg.alt || '' : '';
        var vpWidth = vp.offsetWidth;
        var vpHeight = vp.offsetHeight;
        var count = state.images.length;
        var speed = state.cfg.speed || 250;
        var transition = state.cfg.transition || 'fade';

        var baseStyle = 'width:' + vpWidth + 'px;height:' + vpHeight + 'px;object-fit:contain;position:static';

        if (transition === 'slide') {
            // TRACK: flex row
            var track = document.createElement('span');
            track.className = 'hover-slider-track';
            track.style.cssText = 'display:flex;width:' + (vpWidth * count) + 'px;height:' + vpHeight + 'px;transition:transform ' + speed + 'ms ease-out';

            if (baseImg) {
                baseImg.style.cssText += ';' + baseStyle + ';flex:none';
                track.appendChild(baseImg);
                state.slides.push(baseImg);
            }
            for (var i = 1; i < count; i++) {
                var slide = document.createElement('img');
                slide.src = state.images[i]; slide.alt = alt;
                slide.style.cssText = baseStyle + ';flex:none';
                track.appendChild(slide);
                state.slides.push(slide);
            }
            vp.innerHTML = '';
            vp.appendChild(track);
            state.track = track;
        } else {
            // STACKED: base in flow, overlays absolute (fade/instant)
            if (baseImg) {
                baseImg.style.cssText += ';' + baseStyle;
                state.slides.push(baseImg);
            }
            var transStyle = transition === 'fade' ? ';transition:opacity ' + speed + 'ms ease' : '';
            for (var j = 1; j < count; j++) {
                var overlay = document.createElement('img');
                overlay.className = 'hover-slider-overlay';
                overlay.src = state.images[j]; overlay.alt = alt;
                overlay.style.cssText = 'position:absolute;top:0;left:0;' + baseStyle.replace('position:static','') + ';opacity:0;pointer-events:none' + transStyle;
                vp.appendChild(overlay);
                state.slides.push(overlay);
            }
            state.useOverlay = true;
        }
    }

    function goToSlide(state, index) {
        var count = state.images.length;
        if (state.cfg.loop) { index = ((index % count) + count) % count; }
        else { index = Math.max(0, Math.min(count - 1, index)); }
        if (index === state.currentIndex && state.slidesCreated) return;

        ensureSlidesCreated(state);
        state.currentIndex = index;

        if (state.useOverlay) {
            var overlays = state.viewport.querySelectorAll('.hover-slider-overlay');
            overlays.forEach(function(o) { o.style.opacity = '0'; o.style.pointerEvents = 'none'; });
            if (index > 0 && state.slides[index]) {
                state.slides[index].style.opacity = '1';
                state.slides[index].style.pointerEvents = 'auto';
            }
        } else {
            var vpWidth = state.viewport.offsetWidth;
            state.track.style.transform = 'translateX(-' + (index * vpWidth) + 'px)';
        }

        updateIndicators(state);
        updateArrows(state);
    }

    // =============================================
    // HOVER
    // =============================================
    function bindHoverEvents(state) {
        state.el.addEventListener('mouseenter', function() {
            if (state.cfg.hoverFlip && state.currentIndex === 0) goToSlide(state, 1);
        });
        state.el.addEventListener('mouseleave', function() {
            if (state.cfg.autoReturn) goToSlide(state, 0);
        });
    }

    // =============================================
    // ARROWS
    // =============================================
    function createArrows(state) {
        var prevSvg = '<svg viewBox="0 0 24 24"><path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>';
        var nextSvg = '<svg viewBox="0 0 24 24"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>';

        var prev = document.createElement('button');
        prev.className = 'hover-slider-arrow hover-slider-arrow--prev';
        prev.type = 'button';
        prev.innerHTML = prevSvg;

        var next = document.createElement('button');
        next.className = 'hover-slider-arrow hover-slider-arrow--next';
        next.type = 'button';
        next.innerHTML = nextSvg;

        prev.addEventListener('click', function(e) { e.preventDefault(); e.stopPropagation(); goToSlide(state, state.currentIndex - 1); });
        next.addEventListener('click', function(e) { e.preventDefault(); e.stopPropagation(); goToSlide(state, state.currentIndex + 1); });

        state.el.appendChild(prev);
        state.el.appendChild(next);
        state.arrows = { prev: prev, next: next };
        updateArrows(state);
    }

    function updateArrows(state) {
        if (!state.arrows || state.cfg.loop) return;
        state.arrows.prev.classList.toggle('disabled', state.currentIndex === 0);
        state.arrows.next.classList.toggle('disabled', state.currentIndex === state.images.length - 1);
    }

    // =============================================
    // MOUSE TRACKING
    // =============================================
    function initMouseTracking(state) {
        var rafId = null;
        state.el.addEventListener('mousemove', function(e) {
            if (rafId) return;
            rafId = requestAnimationFrame(function() {
                var rect = state.el.getBoundingClientRect();
                var relativeX = (e.clientX - rect.left) / rect.width;
                var idx = Math.min(state.images.length - 1, Math.max(0, Math.floor(relativeX * state.images.length)));
                goToSlide(state, idx);
                rafId = null;
            });
        });
    }

    // =============================================
    // SWIPE
    // =============================================
    function initSwipe(state) {
        var startX = 0, startY = 0, dragging = false;
        var el = state.el;
        el.addEventListener('touchstart', function(e) { startX = e.touches[0].clientX; startY = e.touches[0].clientY; dragging = true; }, { passive: true });
        el.addEventListener('touchmove', function(e) {
            if (!dragging) return;
            if (Math.abs(e.touches[0].clientX - startX) > Math.abs(e.touches[0].clientY - startY) && Math.abs(e.touches[0].clientX - startX) > 10) e.preventDefault();
        }, { passive: false });
        el.addEventListener('touchend', function(e) {
            if (!dragging) return; dragging = false;
            var dx = e.changedTouches[0].clientX - startX;
            if (Math.abs(dx) > 30) goToSlide(state, state.currentIndex + (dx < 0 ? 1 : -1));
        }, { passive: true });
    }

    // =============================================
    // INDICATORS
    // =============================================
    function createIndicators(state) {
        var type = state.deviceCfg.indicator, pos = state.deviceCfg.indicatorPos;
        if (type === 'none') return;

        if (type === 'counter') {
            var cls = pos === 'top' ? 'hover-slider-counter--top' : 'hover-slider-counter--bottom';
            var counter = document.createElement('span');
            counter.className = 'hover-slider-counter ' + cls;
            counter.textContent = '1/' + state.images.length;
            state.el.appendChild(counter);
            state.counter = counter;
            return;
        }

        var wrapper = document.createElement('span');
        wrapper.className = 'hover-slider-indicators indicator-' + type + ' hover-slider-indicators--' + pos;
        var clickable = state.deviceCfg.nav && state.deviceCfg.nav.indexOf('dots_click') !== -1;

        for (var i = 0; i < state.images.length; i++) {
            var item = document.createElement('span');
            if (type === 'bars') { item.className = 'hover-slider-bar'; item.style.width = (100 / state.images.length) + '%'; }
            else if (type === 'dots') { item.className = 'hover-slider-dot'; }
            else if (type === 'pills') { item.className = 'hover-slider-pill'; }
            if (i === 0) item.classList.add('active');
            if (clickable) { item.classList.add('clickable'); item.dataset.index = i; }
            wrapper.appendChild(item);
        }

        if (clickable) wrapper.addEventListener('click', function(e) {
            var t = e.target.closest('.clickable');
            if (t) {
                e.preventDefault();
                e.stopPropagation();
                goToSlide(state, parseInt(t.dataset.index, 10));
            }
        });

        state.el.appendChild(wrapper);
        state.indicators = wrapper;
    }

    function updateIndicators(state) {
        if (state.indicators) {
            var ch = state.indicators.children;
            for (var i = 0; i < ch.length; i++) ch[i].classList.toggle('active', i === state.currentIndex);
        }
        if (state.counter) state.counter.textContent = (state.currentIndex + 1) + '/' + state.images.length;
    }

    // =============================================
    // DYNAMIC CONTENT
    // =============================================
    function debouncedInit() {
        if (initTimeout) clearTimeout(initTimeout);
        initTimeout = setTimeout(initAll, 100);
    }

    if (typeof MutationObserver !== 'undefined') {
        new MutationObserver(function(muts) {
            for (var i = 0; i < muts.length; i++) { if (muts[i].addedNodes.length) { debouncedInit(); return; } }
        }).observe(document.body, { childList: true, subtree: true });
    }
    window.addEventListener('contentUpdated', debouncedInit);

    // =============================================
    // INIT
    // =============================================
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function() { initAll(); });
    } else {
        initAll();
    }

    window.rollpixImageFlip = { init: initAll };
    window.rollpixHoverSlider = { init: initSliders };
})();
</script>
